# Yellow Tea Site - Production Environment Variables
# Copy this to .env file on your VPS

# Application
NODE_ENV=production
PORT=3000

# Domain
DOMAIN=yellowtea.in

# Database (if you add one later)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=yellow_tea
# DB_USER=yellow_tea_user
# DB_PASSWORD=your_secure_password

# JWT Secret (generate a secure one)
JWT_SECRET=your_super_secure_jwt_secret_here

# API Keys (if needed)
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG...

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/pm2/yellow-tea-combined.log

# Cache (if you add Redis later)
# REDIS_URL=redis://localhost:6379

# Monitoring
ENABLE_MONITORING=true 