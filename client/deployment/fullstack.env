# Yellow Tea Full-Stack - Production Environment Variables
# Copy this to .env files on your VPS

# ===== FRONTEND ENVIRONMENT =====
# Frontend .env file: /var/www/yellow-tea-frontend/.env

NODE_ENV=production
PORT=3000
API_URL=https://yellowtea.in/api
VITE_API_URL=https://yellowtea.in/api

# ===== BACKEND ENVIRONMENT =====
# Backend .env file: /var/www/yellow-tea-backend/.env

# Application
NODE_ENV=production
PORT=5000
DOMAIN=yellowtea.in

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_here_generate_with_crypto
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Database Configuration
DATABASE_URL=your_database_connection_string
# Example for PostgreSQL: postgresql://username:password@localhost:5432/yellow_tea_db
# Example for MongoDB: mongodb://localhost:27017/yellow_tea_db
# Example for MySQL: mysql://username:password@localhost:3306/yellow_tea_db

# Email Configuration (if using email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yellowtea.in

# Payment Gateway (if using Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Redis Configuration (if using Redis for caching/sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/pm2/yellow-tea-backend-combined.log

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# CORS Configuration
CORS_ORIGIN=https://yellowtea.in,https://www.yellowtea.in
CORS_CREDENTIALS=true

# Monitoring
ENABLE_MONITORING=true
ENABLE_HEALTH_CHECKS=true

# ===== GENERATE SECURE SECRETS =====
# Run these commands to generate secure secrets:

# Generate JWT Secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Generate Redis Password:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Generate Database Password:
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))" 